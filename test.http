### Variables
@baseUrl = http://127.0.0.1:8000/api
@email = test@example.com
@password = password123

# =============================================================================
# AUTHENTICATION
# =============================================================================

### 1. Register a new user
# Creates a new user record and returns user details.
POST {{baseUrl}}/register
Content-Type: application/json
Accept: application/json

{
    "name": "Test User",
    "email": "{{email}}",
    "password": "{{password}}",
    "password_confirmation": "{{password}}"
}

### 2. Login
# Authenticates credentials and returns a Sanctum 'access_token'.
# @name loginRequest
POST {{baseUrl}}/login
Content-Type: application/json
Accept: application/json

{
    "email": "{{email}}",
    "password": "{{password}}"
}

### 3. Logout
# Revokes the current access token. Requires valid Bearer Token.
POST {{baseUrl}}/logout
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}


# =============================================================================
# THREADS
# =============================================================================

### 4. Get All Threads
# Retrieves a list of threads. Supports optional search: ?search=keyword
GET {{baseUrl}}/threads
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 5. Create a Thread
# Creates a new discussion thread.
POST {{baseUrl}}/threads
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

{
    "name": "Old Thread Title 3",
    "description": "This is the content of the new thread."
}

### 6. Get Single Thread details
# Fetches details for a specific thread by ID.
GET {{baseUrl}}/threads/1
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 7. Join a Thread
# Adds the authenticated user to the thread's member list (pivot table).
POST {{baseUrl}}/threads/1/join
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 8. Leave a Thread
# Removes the authenticated user from the thread's member list.
DELETE {{baseUrl}}/threads/1/leave
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 9. Get Posts within a Thread
# Lists all posts for a thread. Use ?sort=trending to sort by score.
GET {{baseUrl}}/threads/1/posts?sort=trending
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 10. Create a Post in a Thread
# Creates a new post attached to a specific thread.
POST {{baseUrl}}/threads/1/post
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

{
    "content": "pisztiposzti"
}


# =============================================================================
# POSTS & VOTING
# =============================================================================

### 11. Get Global Posts Feed
# Retrieves all posts.
GET {{baseUrl}}/posts
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 12. Get Single Post
# Fetches a post by ID, including its calculated score and current user's vote.
GET {{baseUrl}}/posts/11
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 13. Vote on a Post
# is_upvote (JSON boolean field): true for upvote, false for downvote.
# Note: Sending the same value twice toggles (deletes) the vote.
POST {{baseUrl}}/posts/1/vote
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

{
    "is_upvote": true
}


# =============================================================================
# USERS
# =============================================================================

### 14. List Users
# Returns a list of users. Supports ?search=name
GET {{baseUrl}}/users
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 15. Get User Profile
# Fetches public profile information for a specific user.
GET {{baseUrl}}/users/3
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 16. Get Threads joined by User
# Lists all threads that the specified user has joined.
GET {{baseUrl}}/users/1/threads
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

### 17. Update User Profile
# Updates the authenticated user's name or email.
# TODO: Implement 404/403 handling for non-existent users or unauthorized edits.
PUT {{baseUrl}}/users/54
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{loginRequest.response.body.access_token}}

{
    "name": "Updated Name",
    "email": "updated_email@example.com"
}
